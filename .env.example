ASAN_PROVIDER=localfree
ASAN_REPOSITORY_BACKEND=sqlite
ASAN_SQLITE_PATH=./asanappeal.db
ASAN_SQLITE_TIMEOUT_SECONDS=5
ASAN_SQLITE_BUSY_TIMEOUT_MS=5000
ASAN_SQLITE_JOURNAL_MODE=WAL
ASAN_SQLITE_SYNCHRONOUS=NORMAL
ASAN_SQLITE_MAX_WRITE_RETRIES=5
ASAN_SQLITE_WRITE_RETRY_BACKOFF_MS=50
ASAN_SQLITE_BACKUP_DIR=./.data/backups
ASAN_SQLITE_BACKUP_PAGES_PER_STEP=128
ASAN_EVIDENCE_ROOT=./.data/evidence
ASAN_EVIDENCE_MAX_BYTES=26214400
ASAN_EVIDENCE_SIGNED_URL_TTL_SECONDS=900
ASAN_EVIDENCE_SIGNING_SECRET=change-me-for-production
ASAN_EVIDENCE_THUMBNAIL_MAX_SIZE=512
ASAN_PRIVACY_CASE_RETENTION_DAYS=365
ASAN_PRIVACY_EVIDENCE_RETENTION_DAYS=180
ASAN_PRIVACY_EXPORT_DIR=./.data/privacy_exports
ASAN_REQUEST_MAX_BODY_BYTES=524288
ASAN_REQUEST_RATE_LIMIT_WINDOW_SECONDS=60
ASAN_REQUEST_RATE_LIMIT_MAX_REQUESTS=120
ASAN_AUTH_RATE_LIMIT_MAX_REQUESTS=20
ASAN_ABUSE_MAX_EVIDENCE_ITEMS=8
ASAN_ABUSE_MAX_TEXT_CHARS=6000
ASAN_ABUSE_SPAM_WINDOW_SECONDS=3600
ASAN_ABUSE_DUPLICATE_THRESHOLD=2
ASAN_LOCAL_ML_ENABLED=true
ASAN_LOCAL_ML_BOOTSTRAP_DIR=./data/local_ml
ASAN_LOCAL_ML_FEEDBACK_DIR=./.data/local_ml_feedback
ASAN_LOCAL_ML_INCLUDE_SQLITE_FEEDBACK=true
ASAN_LOCAL_ML_MIN_CONFIDENCE=0.58
ASAN_EVAL_DATASET_DIR=./data/evals
ASAN_EVAL_ARTIFACT_DIR=./.data/evals
ASAN_EVAL_INTAKE_MIN_ACCURACY=0.85
ASAN_EVAL_ROUTING_MIN_ACCURACY=0.90
ASAN_EVAL_PRIORITY_MIN_ACCURACY=0.85
ASAN_EVAL_VERIFICATION_MIN_ACCURACY=0.80
ASAN_LOCAL_LLM_BACKEND=heuristic
ASAN_OLLAMA_URL=http://127.0.0.1:11434
ASAN_OLLAMA_MODEL=gemma3:4b
ASAN_OLLAMA_TIMEOUT_SECONDS=45
ASAN_HUMAN_REVIEW_CONFIDENCE_THRESHOLD=0.62
ASAN_AUTH_ENABLED=true
ASAN_AUTH_TOKEN_TTL_HOURS=12
ASAN_AUTH_PASSWORD_ITERATIONS=600000
ASAN_AUTH_SEED_DEMO_ACCOUNTS=true
ASAN_AUTH_DEMO_CITIZEN_USERNAME=citizen.demo
ASAN_AUTH_DEMO_CITIZEN_PASSWORD=citizen-demo-pass
ASAN_AUTH_DEMO_OPERATOR_USERNAME=operator.demo
ASAN_AUTH_DEMO_OPERATOR_PASSWORD=operator-demo-pass
ASAN_AUTH_DEMO_REVIEWER_USERNAME=reviewer.demo
ASAN_AUTH_DEMO_REVIEWER_PASSWORD=reviewer-demo-pass
ASAN_AUTH_DEMO_INSTITUTION_USERNAME=institution.roads
ASAN_AUTH_DEMO_INSTITUTION_PASSWORD=institution-demo-pass
ASAN_AUTH_DEMO_INSTITUTION_SLUG=asan-road-maintenance-agency
ASAN_AUTH_DEMO_ADMIN_USERNAME=admin.demo
ASAN_AUTH_DEMO_ADMIN_PASSWORD=admin-demo-pass

